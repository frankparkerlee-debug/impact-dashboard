# Copy to .env.local for dev. In production these are Render env vars (see render.yaml).
# NEVER commit real values.

# monday.com — server-only (the same token from ../monday.env)
MONDAY_API_TOKEN=

# Clerk auth (Organizations == client tenants)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Render Postgres (Render injects this automatically in prod via render.yaml)
DATABASE_URL=
